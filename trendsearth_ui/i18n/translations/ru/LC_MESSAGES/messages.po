msgid "Please enter and confirm your new password."
msgstr "Пожалуйста, введите и подтвердите свой новый пароль."

#: trendsearth_ui/callbacks/auth.py:1244
msgid "Passwords do not match. Please try again."
msgstr "Пароли не совпадают. Пожалуйста, попробуйте еще раз."

#: trendsearth_ui/callbacks/auth.py:1253
#: trendsearth_ui/callbacks/profile.py:265
msgid "Password must be at least 12 characters long."
msgstr "Пароль должен содержать не менее 12 символов."

