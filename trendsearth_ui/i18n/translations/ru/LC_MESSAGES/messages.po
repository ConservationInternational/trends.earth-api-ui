msgid "Please select a .tar.gz script archive to upload."
msgstr "Пожалуйста, выберите для загрузки архив скриптов в формате .tar.gz."

#: trendsearth_ui/callbacks/admin.py:951
msgid ""
"Invalid file type. The API requires a .tar.gz archive containing a "
"configuration.json file."
msgstr ""
"Недопустимый тип файла. API требует наличия архива .tar.gz, содержащего файл"
" configuration.json."

#: trendsearth_ui/callbacks/admin.py:981
#, python-brace-format
msgid "Script '{name}' uploaded successfully."
msgstr "Скрипт &#39;{name}&#39; успешно загружен."

#: trendsearth_ui/callbacks/admin.py:990 trendsearth_ui/callbacks/admin.py:992
msgid "Invalid script archive."
msgstr "Недействительный архив скрипта."

#: trendsearth_ui/callbacks/admin.py:994
#, python-brace-format
msgid "Error uploading script: {detail}"
msgstr "Ошибка при загрузке скрипта: {detail}"

#: trendsearth_ui/callbacks/admin.py:1002
msgid "Permission denied. Only admins and superadmins can create scripts."
msgstr ""
"Доступ запрещен. Создавать скрипты могут только администраторы и "
"суперадминистраторы."

#: trendsearth_ui/callbacks/admin.py:1010
#, python-brace-format
msgid "Failed to upload script. Server responded with status {status}."
msgstr "Не удалось загрузить скрипт. Сервер ответил со статусом {status}."

#: trendsearth_ui/callbacks/admin.py:1021
msgid "Upload timed out. Please try again with a smaller file."
msgstr ""
"Время загрузки истекло. Пожалуйста, попробуйте еще раз с файлом меньшего "
"размера."

#: trendsearth_ui/callbacks/admin.py:1200
msgid "Rate limits have been successfully reset for all users and endpoints."
msgstr ""
"Ограничения скорости запросов успешно сброшены для всех пользователей и "
"конечных устройств."

#: trendsearth_ui/callbacks/admin.py:1210
#, python-brace-format
msgid "Failed to reset rate limits. Status: {status}"
msgstr "Не удалось сбросить лимиты запросов. Статус: {status}"

#: trendsearth_ui/callbacks/admin.py:1234
#, python-brace-format
msgid "Error resetting rate limits: {error}"
msgstr "Ошибка при сбросе лимитов скорости: {error}"

#: trendsearth_ui/callbacks/admin.py:1440
msgid "Error: No rate limit selected."
msgstr "Ошибка: Не выбрано ограничение скорости."

#: trendsearth_ui/callbacks/admin.py:1481
#, python-brace-format
msgid "Rate limit for {identifier} has been successfully reset."
msgstr "Лимит запросов для {identifier} успешно сброшен."

#: trendsearth_ui/callbacks/admin.py:1498
#, python-brace-format
msgid "Rate limit for {identifier} not found. It may have already expired."
msgstr ""
"Ограничение на количество запросов для {идентификатор} не найдено. Возможно,"
" оно уже истекло."

#: trendsearth_ui/callbacks/admin.py:1510
#, python-brace-format
msgid "Failed to reset rate limit. Status: {status}"
msgstr "Не удалось сбросить лимит запросов. Статус: {status}"

#: trendsearth_ui/callbacks/admin.py:1538
#, python-brace-format
msgid "Error resetting rate limit: {error}"
msgstr "Ошибка сброса лимита запросов: {error}"

#: trendsearth_ui/callbacks/auth.py:402 trendsearth_ui/callbacks/auth.py:1840
msgid "Please enter both email and password."
msgstr "Пожалуйста, введите адрес электронной почты и пароль."

#: trendsearth_ui/callbacks/auth.py:437 trendsearth_ui/callbacks/auth.py:1867
msgid "Login failed: Invalid response format."
msgstr "Ошибка входа: Неверный формат ответа."

#: trendsearth_ui/callbacks/auth.py:483
msgid "Login successful!"
msgstr "Вход выполнен успешно!"

#: trendsearth_ui/callbacks/auth.py:505
msgid "Failed to retrieve user information."
msgstr "Не удалось получить информацию о пользователе."

#: trendsearth_ui/callbacks/auth.py:513 trendsearth_ui/callbacks/auth.py:1900
msgid "Invalid credentials."
msgstr "Неверные учетные данные."

#: trendsearth_ui/callbacks/auth.py:521
msgid "Your account is locked due to too many failed login attempts. "
msgstr ""
"Ваш аккаунт заблокирован из-за слишком большого количества неудачных попыток"
" входа. "

#: trendsearth_ui/callbacks/auth.py:523
msgid "Please use the 'Forgot Password' link below to reset your password."
msgstr "Для сброса пароля воспользуйтесь ссылкой «Забыли пароль» ниже."

#: trendsearth_ui/callbacks/auth.py:526
msgid "Your account is temporarily locked. "
msgstr "Ваш аккаунт временно заблокирован. "

#: trendsearth_ui/callbacks/auth.py:527
#, python-brace-format
msgid "Please try again in {minutes} minute(s)."
msgstr "Пожалуйста, попробуйте еще раз через {минут} минут(ы)."

#: trendsearth_ui/callbacks/auth.py:547
msgid "Login failed: Connection timeout. Please try again later."
msgstr ""
"Ошибка входа: истекло время ожидания соединения. Пожалуйста, попробуйте "
"позже."

#: trendsearth_ui/callbacks/auth.py:559
msgid ""
"Login failed: Cannot connect to authentication server. Please check the "
"server status."
msgstr ""
"Ошибка входа: Не удалось подключиться к серверу аутентификации. Пожалуйста, "
"проверьте состояние сервера."

#: trendsearth_ui/callbacks/auth.py:571
#, python-brace-format
msgid "Login failed: {error}"
msgstr "Ошибка входа: {error}"

#: trendsearth_ui/callbacks/auth.py:790 trendsearth_ui/callbacks/auth.py:1486
msgid "Please enter your email address."
msgstr "Пожалуйста, введите свой адрес электронной почты."

#: trendsearth_ui/callbacks/auth.py:803 trendsearth_ui/callbacks/auth.py:1522
msgid "Please enter a valid email address."
msgstr "Пожалуйста, введите действительный адрес электронной почты."

