#, python-brace-format
msgid "Rate limit for {identifier} not found. It may have already expired."
msgstr ""
"محدودیت نرخ برای {identifier} یافت نشد. ممکن است قبلاً منقضی شده باشد."

#: trendsearth_ui/callbacks/admin.py:1510
#, python-brace-format
msgid "Failed to reset rate limit. Status: {status}"
msgstr "تنظیم مجدد محدودیت سرعت ناموفق بود. وضعیت: {status}"

#: trendsearth_ui/callbacks/admin.py:1538
#, python-brace-format
msgid "Error resetting rate limit: {error}"
