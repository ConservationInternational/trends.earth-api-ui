msgstr "تنظیم مجدد محدودیت‌های نرخ ناموفق بود. وضعیت: {status}"

#: trendsearth_ui/callbacks/admin.py:1234
#, python-brace-format
msgid "Error resetting rate limits: {error}"
msgstr "خطا در تنظیم مجدد محدودیت‌های سرعت: {error}"

